<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_title"
            android:textAppearance="@style/TextAppearance.App.Title"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/sortKindGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sort_manual" />

            <RadioButton
                android:id="@+id/rbName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sort_by_name" />

            <RadioButton
                android:id="@+id/rbCreated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sort_by_created" />

            <RadioButton
                android:id="@+id/rbRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sort_by_recent" />

            <RadioButton
                android:id="@+id/rbField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sort_by_field" />

        </RadioGroup>

        <TextView
            android:id="@+id/sortFieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_field_hint"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/spinnerSortField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/sortBodyPartLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_body_part_hint"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:paddingTop="8dp"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/spinnerBodyPart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplySort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/apply" />

    </LinearLayout>

</ScrollView>
