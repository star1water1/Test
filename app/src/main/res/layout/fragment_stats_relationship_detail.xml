<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/stats_relation_network_title"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 네트워크 메트릭 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_network_metrics"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <TextView
                android:id="@+id/textNetworkDensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textAvgConnections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textDescCompleteness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textReciprocalPairs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 관계 유형 분포 PieChart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_rel_type_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chartTypeDist"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- TOP 연결 캐릭터 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_rel_top_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listTopConnected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 고립 캐릭터 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_isolated_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listIsolated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 강도/방향성 분석 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_intensity_direction_title"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <TextView
                android:id="@+id/textAvgIntensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textDirectionRatio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartIntensityDist"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 관계 변화 시간 추세 -->
            <TextView
                android:id="@+id/labelTimeTrend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_rel_time_trend"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                android:visibility="gone" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartTimeTrend"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="@dimen/stats_margin_lg"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
