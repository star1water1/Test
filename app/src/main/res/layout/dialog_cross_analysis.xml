<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stats_cross_field1"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <Spinner
        android:id="@+id/spinnerField1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stats_cross_field2"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <Spinner
        android:id="@+id/spinnerField2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/filterLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stats_cross_filter_field"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <Spinner
            android:id="@+id/spinnerFilterField"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/stats_cross_filter_value_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editFilterValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</LinearLayout>
