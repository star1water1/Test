<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/supplement_title"
        app:titleTextColor="@color/on_primary" />

    <!-- 공유 필터 헤더: 세계관/작품 스피너 — 두 내부 탭이 함께 사용 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/filterHeaderCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/stats_padding_content"
        android:layout_marginEnd="@dimen/stats_padding_content"
        android:layout_marginTop="@dimen/stats_margin_sm"
        app:cardCornerRadius="@dimen/stats_card_corner_radius"
        app:cardElevation="@dimen/stats_card_elevation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/stats_padding_card"
            android:paddingEnd="@dimen/stats_padding_card"
            android:paddingTop="@dimen/stats_margin_sm"
            android:paddingBottom="@dimen/stats_margin_sm">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="@dimen/stats_margin_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_universes"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/stats_text_body_sm" />

                <Spinner
                    android:id="@+id/spinnerUniverse"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/stats_margin_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_novels"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/stats_text_body_sm" />

                <Spinner
                    android:id="@+id/spinnerNovel"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target_min" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/stats_margin_sm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterHeaderCard"
        app:tabMode="fixed" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>
