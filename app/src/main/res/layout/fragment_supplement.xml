<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/supplement_title"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- 빈 상태 -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/supplement_no_characters"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/stats_text_body"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 현황 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/supplement_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <!-- 숫자 카드 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/stats_margin_md">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/stats_margin_sm"
                            app:cardCornerRadius="@dimen/stats_card_corner_radius"
                            app:cardBackgroundColor="@color/primary">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_padding_card">

                                <TextView
                                    android:id="@+id/targetCountText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_primary"
                                    android:textSize="@dimen/stats_text_number_lg"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/supplement_target_count"
                                    android:textColor="@color/on_primary"
                                    android:textSize="@dimen/stats_text_body_sm" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/stats_margin_sm"
                            app:cardCornerRadius="@dimen/stats_card_corner_radius">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_padding_card">

                                <TextView
                                    android:id="@+id/totalCountText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/on_surface"
                                    android:textSize="@dimen/stats_text_number_lg"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/supplement_total_count"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="@dimen/stats_text_body_sm" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- 완료율 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/stats_margin_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/supplement_completion_rate"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/stats_text_body_sm" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/completionRateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/completionProgressBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/stats_progress_bar_height"
                        android:max="100"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <!-- 보충 기준 설정 버튼 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSettings"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/supplement_settings_title" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 필터/정렬 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <!-- 세계관/작품 필터 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/stats_margin_md">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="@dimen/stats_margin_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_universes"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/stats_text_body_sm" />

                            <Spinner
                                android:id="@+id/spinnerUniverse"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/touch_target_min" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/stats_margin_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tab_novels"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/stats_text_body_sm" />

                            <Spinner
                                android:id="@+id/spinnerNovel"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/touch_target_min" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 이슈별 필터 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/supplement_filter_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:layout_marginBottom="@dimen/stats_margin_xs" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/issueFilterChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <!-- 정렬 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/supplement_sort_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:layout_marginBottom="@dimen/stats_margin_xs" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/sortChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 시작 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/startCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:id="@+id/startDescText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartSupplement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/supplement_start" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 대상 목록 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:id="@+id/listHeaderText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/stats_text_heading"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
