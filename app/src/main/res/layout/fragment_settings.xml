<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/tab_settings" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Theme -->
            <LinearLayout
                android:id="@+id/themeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme"
                        android:textAppearance="@style/TextAppearance.App.Title"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/themeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />

            <!-- Section: Backup Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_status_title"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/backupStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- Auto backup options -->
            <LinearLayout
                android:id="@+id/backupOptionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/backup_options"
                        android:textAppearance="@style/TextAppearance.App.Title"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/backupOptionsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.App.BodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Restore from backup -->
            <LinearLayout
                android:id="@+id/backupRestoreRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_backup"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />

            <!-- Section: 데이터 (엑셀·월드패키지) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_data"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <!-- Export -->
            <LinearLayout
                android:id="@+id/exportRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_export"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- World Package Export -->
            <LinearLayout
                android:id="@+id/worldPackageRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/share_world_package"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Import -->
            <LinearLayout
                android:id="@+id/importRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_import"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Section: 데이터 관리 (휴지통·저장소·압축·이력 + 점검) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_data"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <!-- Trash (B-7) -->
            <LinearLayout
                android:id="@+id/trashRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trash_title"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_trash_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Storage (저장 공간 분석/정리) -->
            <LinearLayout
                android:id="@+id/storageRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/storage_title"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_storage_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- 이미지 압축 (불러오기 시 자동 압축 설정) -->
            <LinearLayout
                android:id="@+id/imageCompressRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_image_compress_title"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_image_compress_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Operation History (작업 이력) -->
            <LinearLayout
                android:id="@+id/operationHistoryRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/operation_history_title"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_operation_history_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />


            <!-- Integrity Check -->
            <LinearLayout
                android:id="@+id/integrityCheckRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/maintenance_check_integrity"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Reindex displayOrder -->
            <LinearLayout
                android:id="@+id/reindexRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/maintenance_reindex"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Clean orphan data -->
            <LinearLayout
                android:id="@+id/cleanOrphanRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/maintenance_clean_orphan"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/maintenance_clean_orphan_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Check broken images -->
            <LinearLayout
                android:id="@+id/checkImagesRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/maintenance_check_images"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- Maintenance result -->
            <TextView
                android:id="@+id/maintenanceResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />

            <!-- Section: 앱 (오류 로그·초기화·정보) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_section_app"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/errorLogSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="4dp"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:id="@+id/viewErrorLogRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_view_error_log"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_view_error_log_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />

            <!-- App Reset -->
            <LinearLayout
                android:id="@+id/resetAppRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_reset_app"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorError" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_reset_app_desc"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOnSurfaceVariant"
                android:alpha="0.2" />

            <!-- Version info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_about"
                    android:textAppearance="@style/TextAppearance.App.Title"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.BodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
