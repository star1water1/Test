<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- 캐릭터 이미지 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/characterImage"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="@color/surface"
            app:shapeAppearanceOverlay="@style/RoundedImageShape"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 순위 뱃지 (이미지 좌상단 오버랩) -->
        <TextView
            android:id="@+id/rankBadge"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            android:background="@drawable/bg_rank_circle"
            android:layout_marginStart="-4dp"
            android:layout_marginTop="-4dp"
            app:layout_constraintStart_toStartOf="@id/characterImage"
            app:layout_constraintTop_toTopOf="@id/characterImage" />

        <!-- 캐릭터 이름 -->
        <TextView
            android:id="@+id/characterName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/characterImage"
            app:layout_constraintEnd_toStartOf="@id/valueBadge"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/novelName" />

        <!-- 작품명 -->
        <TextView
            android:id="@+id/novelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/characterImage"
            app:layout_constraintEnd_toStartOf="@id/valueBadge"
            app:layout_constraintTop_toBottomOf="@id/characterName"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 값 뱃지 -->
        <TextView
            android:id="@+id/valueBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            android:background="@drawable/bg_score_badge"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="120dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
