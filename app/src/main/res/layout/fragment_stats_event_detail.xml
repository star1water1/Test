<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/stats_events"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 연도별 사건 밀도 BarChart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_event_density"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartYearDensity"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 소설별 사건 수 HorizontalBarChart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_event_per_novel"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/chartNovelEventCounts"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 사건당 평균 캐릭터 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_avg_chars_per_event"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textAvgCharsPerEvent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_number_xl"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 미연결 사건 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_orphan_events"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textOrphanCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_number_xl"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 월별 분포 BarChart -->
            <TextView
                android:id="@+id/labelMonthDist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_month_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartMonthDist"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
