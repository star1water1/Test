<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/stats_data_health"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 데이터 건강도 개요 도넛 차트 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_data_health_overview"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chartDataHealthOverview"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 이미지 미등록 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_no_image"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <TextView
                android:id="@+id/textNoImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <LinearLayout
                android:id="@+id/listNoImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 필드 미입력률 높음 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_incomplete_fields"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />
            <LinearLayout
                android:id="@+id/listIncompleteFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 그룹별 필드 완성도 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_field_completion_by_group"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />
            <LinearLayout
                android:id="@+id/listGroupCompletion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 메모 미작성 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_no_memo"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <TextView
                android:id="@+id/textNoMemoCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <LinearLayout
                android:id="@+id/listNoMemo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 관계 설명 미작성 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_empty_rel_desc"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <TextView
                android:id="@+id/textEmptyRelDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 시간 정밀도 낮은 사건 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_low_precision_label"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <TextView
                android:id="@+id/textLowPrecision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 고립 캐릭터 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_isolated_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />
            <LinearLayout
                android:id="@+id/listIsolated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 사건 미연계 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_unlinked_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />
            <LinearLayout
                android:id="@+id/listUnlinked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 중복 태그 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_duplicate_tags"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />
            <LinearLayout
                android:id="@+id/listDuplicateTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 별명 미작성 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_no_another_name"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <TextView
                android:id="@+id/textNoAnotherNameCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/accent"
                android:layout_marginBottom="@dimen/stats_margin_xs" />
            <LinearLayout
                android:id="@+id/listNoAnotherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
