<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/stats_padding_content">

        <!-- 컨트롤 카드: 뽑기 방식 + 이전/다시 뽑기/다음 + 설정 + 편집 모드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/stats_margin_md"
            app:cardCornerRadius="@dimen/stats_card_corner_radius"
            app:cardElevation="@dimen/stats_card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/stats_padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/random_mode_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/stats_text_body_sm"
                    android:layout_marginBottom="@dimen/stats_margin_xs" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/modeChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="@dimen/stats_margin_sm">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModePure"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/random_mode_pure" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModeIncomplete"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/random_mode_incomplete" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModeLeastRecent"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/random_mode_least_recent" />
                </com.google.android.material.chip.ChipGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/stats_margin_sm">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickBack"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="◀"
                        android:contentDescription="@string/random_prev_pick"
                        android:layout_marginEnd="@dimen/stats_margin_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReroll"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/random_reroll" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickForward"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="▶"
                        android:contentDescription="@string/random_next_pick"
                        android:layout_marginStart="@dimen/stats_margin_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRandomSettings"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="⚙"
                        android:textSize="18sp"
                        android:contentDescription="@string/random_settings_title"
                        android:layout_marginStart="@dimen/stats_margin_xs" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchEditMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/random_edit_mode" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 빈 상태 -->
        <LinearLayout
            android:id="@+id/emptyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/stats_padding_card"
            android:visibility="gone">

            <TextView
                android:id="@+id/emptyRandomText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/supplement_no_characters"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/stats_text_body"
                android:gravity="center"
                android:layout_marginBottom="@dimen/stats_margin_md" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearFilter"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/random_clear_filter"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 미리보기 컨테이너 (편집 OFF) -->
        <LinearLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/imageViewPager"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginBottom="@dimen/stats_margin_md"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/previewName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/stats_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/completionBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:textColor="@color/on_primary"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/previewFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:visibility="gone" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/aliasChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/previewNovel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:layout_marginTop="@dimen/stats_margin_xs" />

                    <TextView
                        android:id="@+id/previewTags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/stats_margin_xs" />

                    <!-- 미흡 항목 칩 — 완성도 검사와 유기적 연결 -->
                    <TextView
                        android:id="@+id/missingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/random_missing_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/stats_margin_sm" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/missingChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/memoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/memo"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:layout_marginBottom="@dimen/stats_margin_xs" />

                    <TextView
                        android:id="@+id/previewMemo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/stats_text_body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 커스텀 필드 (DynamicFieldRenderer 렌더 대상) -->
            <LinearLayout
                android:id="@+id/dynamicFieldsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoDetail"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/random_go_detail"
                android:layout_marginBottom="@dimen/stats_margin_md" />
        </LinearLayout>

        <!-- 편집 컨테이너 (편집 ON) — 캐릭터 편집 화면과 동일한 폼 구성 -->
        <LinearLayout
            android:id="@+id/editContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddImage"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_image" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/imageRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stats_margin_xs"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                android:hint="@string/character_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/stats_margin_sm">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/stats_margin_xs"
                    android:hint="@string/hint_last_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editLastName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/stats_margin_xs"
                    android:hint="@string/hint_first_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                android:hint="@string/hint_another_name"
                app:helperTextEnabled="true"
                app:helperText="@string/hint_another_name_helper">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAnotherName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                android:hint="@string/hint_tags">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_novel"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/stats_text_body_sm" />

            <Spinner
                android:id="@+id/spinnerNovel"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/dynamicFormContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stats_margin_sm"
                android:layout_marginBottom="@dimen/stats_margin_md"
                android:hint="@string/memo">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMemo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveInline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save"
                android:layout_marginBottom="@dimen/stats_margin_md" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
