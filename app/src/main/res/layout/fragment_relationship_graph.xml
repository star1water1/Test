<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/relationship_graph_beta"
        app:titleTextColor="@color/on_primary" />

    <!-- Filter chips -->
    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </HorizontalScrollView>

    <!-- Summary mode warning -->
    <TextView
        android:id="@+id/summaryModeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/graph_summary_bg"
        android:padding="8dp"
        android:textColor="@color/graph_summary_text"
        android:textSize="12sp"
        android:visibility="gone"
        android:gravity="center" />

    <!-- Year slider for temporal relationship view -->
    <LinearLayout
        android:id="@+id/yearSliderLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchTimeView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/graph_time_view"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/yearLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/graphYearSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1.0"
            android:valueFrom="0.0"
            android:valueTo="100.0"
            android:contentDescription="@string/graph_year_slider" />

    </LinearLayout>

    <!-- Stats bar -->
    <LinearLayout
        android:id="@+id/statsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/nodeCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/edgeCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="end" />

    </LinearLayout>

    <!-- Graph view -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.novelcharacter.app.ui.graph.RelationshipGraphView
            android:id="@+id/graphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_menu_mapmode"
                android:alpha="0.3"
                android:layout_marginBottom="12dp"
                android:contentDescription="@string/relationship_graph" />

            <TextView
                android:id="@+id/emptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/graph_no_relationships"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>

    </FrameLayout>

    <!-- Hint bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/graph_tap_hint"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="6dp"
        android:background="@color/surface" />

</LinearLayout>
