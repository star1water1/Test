<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/stats_margin_sm"
    app:cardCornerRadius="@dimen/stats_card_corner_radius"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/outline"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/stats_margin_md">

        <!-- 순번 -->
        <TextView
            android:id="@+id/indexText"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/stats_text_body_sm"
            android:gravity="center" />

        <!-- 캐릭터 이미지 -->
        <ImageView
            android:id="@+id/characterImage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/stats_margin_sm"
            android:layout_marginEnd="@dimen/stats_margin_md"
            android:scaleType="centerCrop"
            android:contentDescription="@string/add_image" />

        <!-- 이름 + 미흡 항목 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/characterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/stats_text_body"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/issueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/stats_text_body_sm"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 완성률 배지 -->
        <TextView
            android:id="@+id/completionBadge"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="@dimen/stats_text_body_sm"
            android:textStyle="bold"
            android:layout_marginStart="@dimen/stats_margin_sm" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
