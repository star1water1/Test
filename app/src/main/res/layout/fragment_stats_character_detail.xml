<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/stats_characters"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 캐릭터 복잡도 TOP 10 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_complexity_ranking"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listComplexity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 태그 분포 PieChart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_tag_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chartTagDistribution"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 소설별 캐릭터 수 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_novel_char_count"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/chartNovelCharCounts"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 생존기간 분포 BarChart (신규: 기존 데이터 시각화) -->
            <TextView
                android:id="@+id/labelSurvival"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_survival_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/chartSurvivalPeriods"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 관계 유형 분포 PieChart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_rel_type_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/chartRelTypeDist"
                android:layout_width="match_parent"
                android:layout_height="@dimen/stats_chart_height"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 관계 수 TOP 10 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_rel_top_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listTopRelChars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 사건 연계 TOP 10 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_event_top_characters"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listTopEventChars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 그룹별 필드 완성도 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_field_completion_by_group"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listGroupCompletion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 필드 완성도 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_field_completion"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listFieldCompletion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 메모/별명 통계 (신규) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_memo_another_name"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <TextView
                android:id="@+id/textMemoStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_xs" />

            <TextView
                android:id="@+id/textAnotherNameRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/stats_text_body"
                android:textColor="@color/on_surface"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

            <!-- 성씨 분포 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_last_name_distribution"
                android:textSize="@dimen/stats_text_heading"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="@dimen/stats_margin_sm" />

            <LinearLayout
                android:id="@+id/listLastNameDist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/stats_margin_lg" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
