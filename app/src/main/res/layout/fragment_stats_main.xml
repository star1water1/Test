<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/tab_statistics"
        app:titleTextColor="@color/on_primary" />

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/stats_padding_content">

            <!-- 작품 필터 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_filter_novel"
                        android:textSize="@dimen/stats_text_body"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginEnd="@dimen/stats_margin_sm" />

                    <Spinner
                        android:id="@+id/spinnerNovelFilter"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/stats_filter_novel" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 전체 요약 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_md"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/stats_padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_summary"
                        android:textSize="@dimen/stats_text_heading"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="@dimen/stats_margin_md" />

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryCharCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_lg"
                                android:textStyle="bold"
                                android:textColor="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_characters"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryEventCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_lg"
                                android:textStyle="bold"
                                android:textColor="@color/accent" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_events"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryRelCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_lg"
                                android:textStyle="bold"
                                android:textColor="@color/search_type_novel" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_relationships"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/stats_margin_md">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryNovelCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_md"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_novels"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryUniverseCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_md"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_universes"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/summaryNameCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/stats_text_number_md"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stats_total_names"
                                android:textSize="@dimen/stats_text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 인사이트 영역 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="@dimen/stats_margin_md"
                        android:layout_marginBottom="@dimen/stats_margin_sm" />

                    <LinearLayout
                        android:id="@+id/insightContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/insightMostActive"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textColor="@color/on_surface"
                            android:drawablePadding="@dimen/stats_margin_xs"
                            android:layout_marginBottom="@dimen/stats_margin_xs" />

                        <TextView
                            android:id="@+id/insightMostConnected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textColor="@color/on_surface"
                            android:drawablePadding="@dimen/stats_margin_xs"
                            android:layout_marginBottom="@dimen/stats_margin_xs" />

                        <TextView
                            android:id="@+id/insightFieldCompletion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textColor="@color/on_surface"
                            android:drawablePadding="@dimen/stats_margin_xs"
                            android:layout_marginBottom="@dimen/stats_margin_xs" />

                        <TextView
                            android:id="@+id/insightRecentActivity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/stats_text_body_sm"
                            android:textColor="@color/on_surface"
                            android:drawablePadding="@dimen/stats_margin_xs" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 캐릭터 분석 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCharacters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_characters"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/charPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 사건 분석 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_events"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/eventPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 관계 분석 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRelationships"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_relationships"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/relPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 커스텀 필드 분석 카드 (신규) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFieldAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_field_analysis"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/fieldAnalysisPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 이름뱅크 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNameBank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_namebank"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/namePreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 데이터 건강도 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDataHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/stats_margin_sm"
                app:cardCornerRadius="@dimen/stats_card_corner_radius"
                app:cardElevation="@dimen/stats_card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/stats_padding_card"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_data_health"
                        android:textSize="@dimen/stats_text_subtitle"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />
                    <TextView
                        android:id="@+id/healthPreview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/stats_text_body_sm"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/stats_margin_xs" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
