<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="560dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_title"
            android:textAppearance="@style/TextAppearance.App.Title"
            android:paddingBottom="4dp" />

        <!-- 작품 섹션 (전역 목록에서만 노출) -->
        <LinearLayout
            android:id="@+id/novelSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_novels_section"
                android:textAppearance="@style/TextAppearance.App.BodyStrong"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/novelChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/noNovelsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_no_novels"
                android:textColor="@color/text_secondary"
                android:textAppearance="@style/TextAppearance.App.BodySmall"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 태그 섹션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_tags_section"
            android:textAppearance="@style/TextAppearance.App.BodyStrong"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/tagChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/noTagsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_no_tags"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:visibility="gone" />

        <!-- 필드 값 섹션 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_field_section"
            android:textAppearance="@style/TextAppearance.App.BodyStrong"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- 발견성 힌트: 필드 필터가 선택 세계관의 필드에만 적용됨(교차세계관 오해 방지) + 계산 필드 제외 안내 -->
        <TextView
            android:id="@+id/fieldFilterHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filter_field_hint"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.App.Caption"
            android:paddingBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerUniverse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Spinner
            android:id="@+id/spinnerField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/valueChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/emptyValuesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_filter_no_values"
            android:textColor="@color/text_secondary"
            android:textAppearance="@style/TextAppearance.App.BodySmall"
            android:visibility="gone" />

        <RadioGroup
            android:id="@+id/matchModeGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <RadioButton
                android:id="@+id/radioExact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/search_filter_exact" />

            <RadioButton
                android:id="@+id/radioContains"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/search_filter_contains" />

        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/apply" />

    </LinearLayout>

</ScrollView>
